{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://first-godot.local/schemas/suspicion-event.schema.json",
  "title": "Suspicion Event Catalog v0.1",
  "description": "Schema for non-verbal suspicion event definitions used in Workstream 3.",
  "type": "object",
  "required": [
    "version",
    "events"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^0\\.[0-9]+$",
      "description": "Schema-aligned catalog version."
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "required": [
        "eventId",
        "statement",
        "trigger",
        "severity",
        "witness",
        "detection",
        "reaction",
        "recoverability"
      ],
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "pattern": "^WS3-E\\d{3}$"
        },
        "statement": {
          "type": "string",
          "minLength": 5
        },
        "trigger": {
          "type": "object",
          "required": [
            "conditions"
          ],
          "additionalProperties": false,
          "properties": {
            "conditions": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 2
              }
            }
          }
        },
        "severity": {
          "type": "object",
          "required": [
            "band",
            "delta"
          ],
          "additionalProperties": false,
          "properties": {
            "band": {
              "type": "string",
              "enum": [
                "Minor",
                "Moderate",
                "Major"
              ]
            },
            "delta": {
              "type": "integer",
              "minimum": 1,
              "maximum": 25
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "band": {
                    "const": "Minor"
                  }
                },
                "required": [
                  "band"
                ]
              },
              "then": {
                "properties": {
                  "delta": {
                    "minimum": 2,
                    "maximum": 5
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "band": {
                    "const": "Moderate"
                  }
                },
                "required": [
                  "band"
                ]
              },
              "then": {
                "properties": {
                  "delta": {
                    "minimum": 6,
                    "maximum": 12
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "band": {
                    "const": "Major"
                  }
                },
                "required": [
                  "band"
                ]
              },
              "then": {
                "properties": {
                  "delta": {
                    "minimum": 13,
                    "maximum": 25
                  }
                }
              }
            }
          ]
        },
        "witness": {
          "type": "object",
          "required": [
            "scope"
          ],
          "additionalProperties": false,
          "properties": {
            "scope": {
              "type": "string",
              "enum": [
                "local",
                "area",
                "institution",
                "global"
              ]
            }
          }
        },
        "detection": {
          "type": "object",
          "required": [
            "mode"
          ],
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "witnessed_only",
                "systemic_allowed",
                "hybrid"
              ]
            },
            "minWitnessCount": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10
            }
          }
        },
        "aggregation": {
          "type": "object",
          "required": [
            "mode"
          ],
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "separate",
                "stack_to_composite"
              ]
            },
            "windowSeconds": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3600
            },
            "threshold": {
              "type": "integer",
              "minimum": 2,
              "maximum": 20
            },
            "compositeEventId": {
              "type": "string",
              "pattern": "^WS3-E\\d{3}$"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "mode": {
                    "const": "stack_to_composite"
                  }
                },
                "required": [
                  "mode"
                ]
              },
              "then": {
                "required": [
                  "windowSeconds",
                  "threshold",
                  "compositeEventId"
                ]
              }
            }
          ]
        },
        "gating": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requiredCueTier": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3
            },
            "minRoutineMastery": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "graceWindowSeconds": {
              "type": "integer",
              "minimum": 0,
              "maximum": 900
            },
            "graceScope": {
              "type": "string",
              "enum": [
                "disabled",
                "spawn_window",
                "district_first_contact"
              ]
            }
          }
        },
        "reaction": {
          "type": "object",
          "required": [
            "firstResponse"
          ],
          "additionalProperties": false,
          "properties": {
            "firstResponse": {
              "type": "string",
              "minLength": 5
            }
          }
        },
        "recoverability": {
          "type": "object",
          "required": [
            "class"
          ],
          "additionalProperties": false,
          "properties": {
            "class": {
              "type": "string",
              "minLength": 3
            }
          }
        }
      }
    }
  }
}
